# Crawpapa-Fetch 配置
# 复制此文件为 .env 并修改配置

# 代理设置（可选）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 缓存目录（可选，默认为 ./cache）
# CRAWLER_CACHE_DIR=./cache

# 输出、数据库和 schema 目录
# CRAWLER_OUTPUT_DIR=./output
# CRAWLER_DB_DIR=./databases
# CRAWLER_SCHEMA_DIR=./schemas
# CRAWLER_LOG_DIR=./logs
# CRAWLER_JOB_DIR=./jobs
# CRAWLER_JOB_WORKERS=2

# URL Frontier、Pipeline 模板和 Cookie/Session 持久化目录
# CRAWLER_FRONTIER_DIR=./frontier
# CRAWLER_TEMPLATE_DIR=./templates
# CRAWLER_COOKIE_DIR=./cookies

# Frontier Bloom filter 参数；容量越大越适合长期去重
# CRAWLER_FRONTIER_BLOOM_CAPACITY=1000000
# CRAWLER_FRONTIER_BLOOM_ERROR_RATE=0.01

# Cookie/Session 持久化（默认 true）
# CRAWLER_PERSIST_COOKIES=true

# SQLite 连接池大小
# CRAWLER_DB_POOL_SIZE=8

# 请求超时（秒，默认 30）
# REQUEST_TIMEOUT=30

# 请求重试次数（默认 3）
# REQUEST_RETRY=3

# 默认每域名 RPS（默认 2）
# CRAWLER_DEFAULT_RATE_LIMIT=2

# TLS 证书校验（默认 true）
# CRAWLER_VERIFY_TLS=true

# 是否默认遵守 robots.txt（默认 true）
# CRAWLER_RESPECT_ROBOTS=true

# SSRF 防护：默认禁止访问 localhost、内网、链路本地、云元数据等地址
# CRAWLER_ALLOW_PRIVATE_NETS=false
# CRAWLER_ALLOWED_DOMAINS=
# CRAWLER_BLOCKED_DOMAINS=

# Playwright 默认 headless；危险启动参数默认关闭
# CRAWLER_BROWSER_HEADLESS=true
# CRAWLER_BROWSER_ALLOW_UNSAFE_FLAGS=false

# 每次返回给 MCP 客户端的最大正文长度
# FETCH_MAX_LENGTH=80000

# 缓存 TTL（秒）
# CACHE_TTL=3600

# 缓存容量上限（MB），0 表示不限制；超出后按最近访问时间淘汰
# CACHE_MAX_SIZE_MB=512

# 每写入多少个缓存文件执行一次容量淘汰
# CACHE_PRUNE_EVERY_WRITES=20

# 事件日志查询最多从文件尾部读取多少行，避免日志变大后全量扫描
# CRAWLER_EVENT_LOG_TAIL_LINES=5000

# 长时间运行时保留的域名级 HTTP Session / 浏览器 Context 上限
# CRAWLER_MAX_DOMAIN_SESSIONS=64
# CRAWLER_MAX_BROWSER_CONTEXTS=16

# 浏览器渲染后检测常见验证码/人机验证页面
# CRAWLER_DETECT_CHALLENGE_PAGES=true

# 自定义验证码/人机验证特征；设置后会覆盖内置默认列表，多个值用英文逗号分隔
# CRAWLER_CHALLENGE_PATTERNS=cf-challenge,captcha,请完成安全验证
